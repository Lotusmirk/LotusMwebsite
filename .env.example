# Environment Variables — Lotusmirk Website
# Copy this file to .env and fill in values as needed.

# Form submission endpoint (e.g., Formspree, Web3Forms, EmailJS)
VITE_FORM_ENDPOINT=

# Google Analytics Measurement ID
VITE_GA_MEASUREMENT_ID=

# Google Maps Embed API Key (for contact page map)
VITE_GOOGLE_MAPS_KEY=
